<!DOCTYPE html>
<html lang="ms">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Pusat Pratonton Laporan RELA</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #0f172a; color: white; margin: 0; padding: 0; height: 100vh; display: flex; flex-direction: column; }
    .glass-header { background: rgba(30, 41, 59, 0.8); backdrop-filter: blur(16px); border-b: 1px solid rgba(255, 255, 255, 0.1); }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="flex flex-col h-full bg-slate-900 overflow-hidden">

  <!-- ================= LOADING OVERLAY ================= -->
  <div id="loading-overlay" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-slate-950 transition-all duration-500">
    <div class="w-16 h-16 border-4 border-slate-800 border-t-blue-500 rounded-full animate-spin mb-4 shadow-lg shadow-blue-500/20"></div>
    <p class="text-xs font-black text-slate-400 uppercase tracking-[0.4em] animate-pulse">Menghubungkan Bilik Kebal Data...</p>
    <p class="text-[10px] text-slate-500 uppercase tracking-widest mt-2">Sila pastikan tab asal sistem RELA tidak ditutup.</p>
  </div>

  <!-- Header Pemantauan -->
  <header class="glass-header p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 z-20 shrink-0 shadow-2xl">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-indigo-800 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/20 rotate-3">
        <i class="fas fa-file-pdf text-white text-xl"></i>
      </div>
      <div class="text-left">
        <h1 id="report-title" class="text-sm font-black tracking-widest text-white uppercase">MENJANA LAPORAN...</h1>
        <p id="report-filename" class="text-[10px] font-bold text-slate-400 mt-0.5 truncate max-w-xs sm:max-w-md uppercase tracking-wider">Menunggu data dari sistem utama</p>
      </div>
    </div>
    <div class="flex items-center gap-3 w-full sm:w-auto shrink-0">
      <button onclick="downloadPDF()" class="flex-1 sm:flex-none px-5 py-3.5 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center justify-center gap-2 transition-all active:scale-95 shadow-lg shadow-blue-500/20">
        <i class="fas fa-download"></i> Muat Turun
      </button>
      <button onclick="printPDF()" class="flex-1 sm:flex-none px-5 py-3.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center justify-center gap-2 transition-all active:scale-95 shadow-lg shadow-emerald-500/20">
        <i class="fas fa-print"></i> Cetak Dokumen
      </button>
      <button onclick="closePreview()" class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 transition-colors">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
  </header>

  <!-- Frame Paparan PDF Sandbox -->
  <main class="flex-1 p-4 bg-slate-950 relative flex justify-center">
    <iframe id="pdf-frame" class="w-full h-full rounded-2xl border border-white/5 shadow-2xl hidden" style="background-color: #525659;"></iframe>
    <div id="fallback-container" class="hidden absolute inset-0 flex flex-col items-center justify-center p-6 text-center">
      <i class="fas fa-file-invoice-dollar text-5xl text-slate-500 mb-4 animate-bounce"></i>
      <h3 class="text-sm font-black uppercase tracking-widest text-slate-300">Dokumen Sedia Untuk Diproses</h3>
      <p class="text-[10px] text-slate-400 font-bold uppercase mt-1 tracking-wider">Sila tekan butang <b>Muat Turun</b> atau <b>Cetak</b> di atas untuk memproses laporan.</p>
    </div>
  </main>

  <script>
    let pdfBlob = null;
    let pdfUrl = null;
    let reportName = "laporan.pdf";

    // 1. Apabila tetingkap dibuka, mulakan protokol jabat tangan (Handshake) dengan penghantar asal (opener)
    window.addEventListener('load', () => {
      if (window.opener) {
        // Beritahu tab Google Apps Script bahawa kita sedia menerima payload
        window.opener.postMessage({ type: 'PREVIEW_READY' }, '*');
      } else {
        document.getElementById('loading-overlay').innerHTML = `
          <div class="text-center p-6">
            <i class="fas fa-lock text-rose-500 text-4xl mb-4"></i>
            <p class="text-xs font-black uppercase tracking-widest text-slate-300">Ralat Sekuriti Sandbox</p>
            <p class="text-[10px] text-slate-500 uppercase mt-1 tracking-wider leading-relaxed">Sesi tidak sah. Sila jana laporan terus menerusi aplikasi utama RELA Batu Pahat.</p>
          </div>
        `;
      }
    });

    // 2. Mendengar penghantaran data Base64 PDF dari aplikasi utama
    window.addEventListener('message', (event) => {
      const payload = event.data;
      if (payload && payload.type === 'PDF_DATA') {
        try {
          reportName = payload.filename || "Laporan_Rela.pdf";
          document.getElementById('report-title').innerText = payload.title || "PRATONTON LAPORAN";
          document.getElementById('report-filename').innerText = reportName;

          // Tukar Base64 DataURI kepada Blob
          const base64Data = payload.data.split(',')[1];
          const byteCharacters = atob(base64Data);
          const byteNumbers = new Array(byteCharacters.length);
          for (let i = 0; i < byteCharacters.length; i++) {
            byteNumbers[i] = byteCharacters.charCodeAt(i);
          }
          const byteArray = new Uint8Array(byteNumbers);
          pdfBlob = new Blob([byteArray], { type: 'application/pdf' });
          pdfUrl = URL.createObjectURL(pdfBlob);

          // Masukkan ke iFrame untuk paparan terus (Jika disokong oleh browser peranti)
          const iframe = document.getElementById('pdf-frame');
          iframe.src = pdfUrl;
          iframe.classList.remove('hidden');

          // Sembunyikan Loading Overlay secara lembut
          const overlay = document.getElementById('loading-overlay');
          overlay.classList.add('opacity-0', 'pointer-events-none');
          setTimeout(() => overlay.remove(), 500);

        } catch (e) {
          console.error(e);
          Swal.fire({
            title: 'Ralat Dekripsi',
            text: 'Gagal mendekod data laporan daripada bilik kebal GAS. Sila jana semula.',
            icon: 'error',
            confirmButtonColor: '#3b82f6',
            background: '#1e293b',
            color: '#fff',
            customClass: { popup: 'rounded-3xl' }
          });
        }
      }
    });

    function downloadPDF() {
      if (pdfBlob) {
        const link = document.createElement('a');
        link.href = pdfUrl;
        link.download = reportName;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        Swal.fire({ title: 'Berjaya', text: 'Laporan dimuat turun.', icon: 'success', toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
      }
    }

    function printPDF() {
      const iframe = document.getElementById('pdf-frame');
      if (iframe && pdfUrl) {
        try {
          iframe.contentWindow.focus();
          iframe.contentWindow.print();
        } catch (e) {
          // Fallback jika iframe print disekat cross-origin pelayar peranti
          window.open(pdfUrl, '_blank');
        }
      }
    }

    function closePreview() {
      if (pdfUrl) URL.revokeObjectURL(pdfUrl);
      window.close();
    }
  </script>
</body>
</html>
